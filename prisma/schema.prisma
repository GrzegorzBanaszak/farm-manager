// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  FullName    String
  Position    Position @default(Employee)
  PhoneNumber String
}

enum Position {
  Owner
  Manager
  Warehouseman
  Employee
}
